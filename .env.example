# CodeMind AI — Environment Variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ── Gemini API ─────────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Backend settings ───────────────────────────────────────────────────────
# Port for FastAPI (default: 8000)
BACKEND_PORT=8000

# Directory where cloned repos are stored temporarily
TEMP_CLONE_DIR=./tmp_repos

# Directory where FAISS indexes are stored
FAISS_INDEX_DIR=./faiss_indexes

# ── Frontend settings ──────────────────────────────────────────────────────
# If backend runs on a different host/port, set this in frontend/.env
# VITE_API_URL=http://localhost:8000

# ── Frontend origin (for CORS) ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

CHROMA_DIR=./chroma_db
